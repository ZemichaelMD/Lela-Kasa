{
  "name": "kasa-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174 --strictPort",
    "build": "tsc --noEmit -p tsconfig.json --incremental false && vite build",
    "preview": "vite preview --port 5174",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json --incremental false",
    "clean": "rm -rf dist node_modules",
    "deploy": "pnpm build && wrangler pages deploy",
    "deploy:prod": "pnpm build && wrangler pages deploy --branch main"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/react-popover": "^1.1.15",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.469.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.0",
    "react-day-picker": "9.13.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.19.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.7"
  }
}
