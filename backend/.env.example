# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
ROLE=web                          # web | worker

APP_URL=http://localhost:3001
CLIENT_URL=http://localhost:5172
ADMIN_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5172,http://localhost:5173

LOG_LEVEL=info                    # trace | debug | info | warn | error | fatal

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/kasa?schema=public
# DIRECT_DATABASE_URL is used by prisma migrate (non-pooled connection)
# DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kasa?schema=public

# ─── Redis / Cache ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Set REDIS_DISABLED=true to fall back to in-memory cache (dev, no Redis needed)
# REDIS_DISABLED=true

# ─── Keys Encryption ──────────────────────────────────────────────────────────
# 32-byte (256-bit) hex string — generate with: openssl rand -hex 32
# Required to encrypt/decrypt integration keys stored in the database.
KEYS_SECRET=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── Auth ─────────────────────────────────────────────────────────────────────
# PASSWORD_PEPPER is appended to the password before hashing (optional extra layer)
# PASSWORD_PEPPER=change_me_pepper
# SESSION_COOKIE_DOMAIN=.kasa.app

# ─── Seed ─────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@kasa.app
SEED_ADMIN_PASSWORD=changeme123!

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local              # local | s3 | r2 | vercel_blob
STORAGE_LOCAL_PATH=./uploads

# S3 (if STORAGE_DRIVER=s3)
# STORAGE_S3_BUCKET=kasa-media
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# Cloudflare R2 (if STORAGE_DRIVER=r2)
# STORAGE_R2_ACCOUNT_ID=
# STORAGE_R2_ACCESS_KEY_ID=
# STORAGE_R2_SECRET_ACCESS_KEY=
# STORAGE_R2_BUCKET=kasa-media

# Vercel Blob (if STORAGE_DRIVER=vercel_blob)
# VERCEL_BLOB_READ_WRITE_TOKEN=

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_DRIVER=log                   # log | smtp | resend  (use log in dev)
MAIL_FROM=noreply@kasa.app

# Resend (if MAIL_DRIVER=resend)
# RESEND_API_KEY=re_...

# SMTP (if MAIL_DRIVER=smtp) — use mailhog/mailpit in dev
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60000             # window in ms
RATE_LIMIT_LIMIT=100             # max requests per window per IP

# ─── Observability ────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...

# ─── SMS ──────────────────────────────────────────────────────────────────────
# ETHIO_SMS_API_KEY=your_key_here
# AFROMESSAGE_TOKEN=your_bearer_token_here
# AFROMESSAGE_SENDER=your_sender_name
# AFROMESSAGE_FROM=your_identifier_id

# ─── Chapa Payments ───────────────────────────────────────────────────────────
CHAPA_SECRET_KEY=CHASECK_TEST-xxx
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-xxx
CHAPA_WEBHOOK_SECRET=replace-with-secret-from-chapa-dashboard
CHAPA_MODE=test
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_CALLBACK_URL=
CHAPA_RETURN_URL=http://localhost:3000/dashboard/billing/checkout/callback

# ─── AI Assistant (OpenAI-compatible) ─────────────────────────────────────────
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
