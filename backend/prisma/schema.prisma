generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  name                    String?
  phone                   String?
  role                    UserRole                 @default(EMPLOYEE)
  isActive                Boolean                  @default(true)
  emailVerified           Boolean                  @default(false)
  lastLoginAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  shopId                  String?
  telegramChatId          String?                  @unique
  username                String?                  @unique
  pinHash                 String?
  auditLogs               AuditLog[]
  ordersConfirmed         CustomerOrder[]          @relation("OrderConfirmedBy")
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  paymentsRecorded        Payment[]                @relation("PaymentRecordedBy")
  salesCreated            Sale[]                   @relation("SaleCreatedBy")
  salesUpdated            Sale[]                   @relation("SaleUpdatedBy")
  salesVoided             Sale[]                   @relation("SaleVoidedBy")
  sessions                Session[]
  ownedShop               Shop?                    @relation("ShopOwner")
  stockMovements          StockMovement[]          @relation("StockMovementBy")
  shop                    Shop?                    @relation("ShopEmployees", fields: [shopId], references: [id])
  userPermissions         UserPermission[]         @relation("UserPermissions")
  verifications           UserVerification[]       @relation("UserVerifications")

  @@index([shopId])
  @@index([email])
  @@index([role])
}

model UserVerification {
  id         String              @id @default(cuid())
  userId     String
  channel    VerificationChannel
  identifier String
  verifiedAt DateTime            @default(now())
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation("UserVerifications", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@index([userId])
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  slug      String
  granted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation("ShopUserPermissions", fields: [shopId], references: [id], onDelete: Cascade)
  user      User     @relation("UserPermissions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId, slug])
  @@index([userId, shopId])
  @@index([shopId])
}

model Shop {
  id                  String               @id @default(cuid())
  name                String
  ownerId             String               @unique
  phone               String?
  address             String?
  currency            String               @default("ETB")
  timezone            String               @default("Africa/Addis_Ababa")
  lowStockThreshold   Int                  @default(2)
  defaultPriceTierId  String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  description         String?
  email               String?
  facebook            String?
  instagram           String?
  latitude            Float?
  longitude           Float?
  mapUrl              String?
  tiktok              String?
  website             String?
  auditLogs           AuditLog[]
  beverages           Beverage[]
  customers           Customer[]
  orders              CustomerOrder[]
  payments            Payment[]
  paymentAccounts     PaymentAccount[]
  paymentTransactions PaymentTransaction[]
  priceTiers          PriceTier[]          @relation("ShopPriceTiers")
  sales               Sale[]
  defaultPriceTier    PriceTier?           @relation("ShopDefaultTier", fields: [defaultPriceTierId], references: [id])
  owner               User                 @relation("ShopOwner", fields: [ownerId], references: [id])
  settings            ShopSetting[]
  stockMovements      StockMovement[]
  subscription        Subscription?
  subscriptionLogs    SubscriptionLog[]
  banners             SystemBanner[]
  users               User[]               @relation("ShopEmployees")
  userPermissions     UserPermission[]     @relation("ShopUserPermissions")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id        String    @id @default(cuid())
  phone     String
  purpose   String
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
}

model Customer {
  id                      String                           @id @default(cuid())
  shopId                  String
  name                    String
  phone                   String?
  notes                   String?
  creditBalanceCents      Int                              @default(0)
  outstandingBoxes        Int                              @default(0)
  outstandingBottles      Int                              @default(0)
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt
  deletedAt               DateTime?
  username                String?                          @unique
  pinHash                 String?
  telegramChatId          String?
  priceTierId             String?
  priceTierLocked         Boolean                          @default(false)
  mustChangePassword      Boolean                          @default(false)
  passwordChangedAt       DateTime?
  email                   String?                          @unique
  emailVerified           Boolean                          @default(false)
  priceTier               PriceTier?                       @relation(fields: [priceTierId], references: [id])
  shop                    Shop                             @relation(fields: [shopId], references: [id])
  emailVerificationTokens CustomerEmailVerificationToken[]
  orders                  CustomerOrder[]
  pinResetTokens          CustomerPinResetToken[]
  payments                Payment[]
  sales                   Sale[]

  @@index([shopId])
  @@index([shopId, name])
  @@index([shopId, creditBalanceCents])
  @@index([deletedAt])
  @@index([username])
  @@index([email])
}

model Beverage {
  id                 String                  @id @default(cuid())
  shopId             String
  name               String
  brand              String?
  sizeMl             Int?
  bottlesPerBox      Int                     @default(24)
  imageUrl           String?
  isActive           Boolean                 @default(true)
  stockBottles       Int                     @default(0)
  emptyBottles       Int                     @default(0)
  emptyBoxes         Int                     @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  deletedAt          DateTime?
  shop               Shop                    @relation(fields: [shopId], references: [id])
  prices             BeveragePrice[]
  orderLines         CustomerOrderLine[]
  containerKasas     SaleContainerKasa[]
  saleLines          SaleLine[]
  returnedContainers SaleReturnedContainer[]
  movements          StockMovement[]

  @@index([shopId])
  @@index([shopId, name])
}

model PriceTier {
  id                String          @id @default(cuid())
  shopId            String
  name              String
  kind              PriceTierKind   @default(CUSTOM)
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  prices            BeveragePrice[]
  customers         Customer[]
  shop              Shop            @relation("ShopPriceTiers", fields: [shopId], references: [id])
  sales             Sale[]
  shopsUsingDefault Shop[]          @relation("ShopDefaultTier")

  @@unique([shopId, name])
  @@index([shopId])
}

model BeveragePrice {
  id                  String    @id @default(cuid())
  beverageId          String
  priceTierId         String
  pricePerBoxCents    Int
  pricePerBottleCents Int
  effectiveFrom       DateTime  @default(now())
  createdAt           DateTime  @default(now())
  createdById         String?
  beverage            Beverage  @relation(fields: [beverageId], references: [id], onDelete: Cascade)
  priceTier           PriceTier @relation(fields: [priceTierId], references: [id])

  @@index([beverageId, priceTierId, effectiveFrom])
}

model PaymentAccount {
  id            String             @id @default(cuid())
  shopId        String
  name          String
  kind          PaymentAccountKind
  holderName    String?
  bankName      String?
  accountNumber String?
  isActive      Boolean            @default(true)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?
  payments      Payment[]
  shop          Shop               @relation(fields: [shopId], references: [id])

  @@unique([shopId, name])
  @@index([shopId])
}

model Sale {
  id                    String                  @id @default(cuid())
  shopId                String
  customerId            String
  saleDate              DateTime
  status                SaleStatus              @default(CONFIRMED)
  priceTierId           String
  subtotalCents         Int                     @default(0)
  paidCents             Int                     @default(0)
  creditDeltaCents      Int                     @default(0)
  boxesOutDelta         Int                     @default(0)
  boxesReturnedOnSale   Int                     @default(0)
  bottlesOutDelta       Int                     @default(0)
  bottlesReturnedOnSale Int                     @default(0)
  notes                 String?
  createdById           String
  voidedAt              DateTime?
  voidedById            String?
  voidReason            String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  updatedById           String?
  orders                CustomerOrder[]
  payments              Payment[]
  createdBy             User                    @relation("SaleCreatedBy", fields: [createdById], references: [id])
  customer              Customer                @relation(fields: [customerId], references: [id])
  priceTier             PriceTier               @relation(fields: [priceTierId], references: [id])
  shop                  Shop                    @relation(fields: [shopId], references: [id])
  updatedBy             User?                   @relation("SaleUpdatedBy", fields: [updatedById], references: [id])
  voidedBy              User?                   @relation("SaleVoidedBy", fields: [voidedById], references: [id])
  containerKasas        SaleContainerKasa[]
  lines                 SaleLine[]
  returnedContainers    SaleReturnedContainer[]
  stockMovements        StockMovement[]

  @@index([shopId, saleDate])
  @@index([shopId, customerId])
  @@index([shopId, status])
  @@index([shopId, createdAt])
}

model SaleLine {
  id                  String   @id @default(cuid())
  saleId              String
  beverageId          String
  boxes               Int      @default(0)
  bottles             Int      @default(0)
  pricePerBoxCents    Int
  pricePerBottleCents Int
  lineTotalCents      Int
  beverage            Beverage @relation(fields: [beverageId], references: [id])
  sale                Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([beverageId])
}

model SaleContainerKasa {
  id         String   @id @default(cuid())
  saleId     String
  beverageId String
  count      Int      @default(1)
  createdAt  DateTime @default(now())
  beverage   Beverage @relation(fields: [beverageId], references: [id])
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model SaleReturnedContainer {
  id         String   @id @default(cuid())
  saleId     String
  beverageId String
  boxes      Int      @default(0)
  bottles    Int      @default(0)
  createdAt  DateTime @default(now())
  beverage   Beverage @relation(fields: [beverageId], references: [id])
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model Payment {
  id               String         @id @default(cuid())
  shopId           String
  saleId           String?
  customerId       String
  amountCents      Int
  method           PaymentMethod
  paymentAccountId String
  reference        String?
  notes            String?
  paidAt           DateTime       @default(now())
  recordedById     String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt
  voidedAt         DateTime?
  voidReason       String?
  customer         Customer       @relation(fields: [customerId], references: [id])
  paymentAccount   PaymentAccount @relation(fields: [paymentAccountId], references: [id])
  recordedBy       User           @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  sale             Sale?          @relation(fields: [saleId], references: [id])
  shop             Shop           @relation(fields: [shopId], references: [id])

  @@index([shopId, paidAt])
  @@index([shopId, customerId])
  @@index([shopId, paymentAccountId])
  @@index([saleId])
}

model StockMovement {
  id           String              @id @default(cuid())
  shopId       String
  beverageId   String
  reason            StockMovementReason
  bottlesDelta      Int
  emptyBoxesDelta   Int?
  emptyBottlesDelta Int?
  saleId            String?
  notes             String?
  createdAt    DateTime            @default(now())
  createdById  String?
  beverage     Beverage            @relation(fields: [beverageId], references: [id])
  createdBy    User?               @relation("StockMovementBy", fields: [createdById], references: [id])
  sale         Sale?               @relation(fields: [saleId], references: [id])
  shop         Shop                @relation(fields: [shopId], references: [id])

  @@index([shopId, beverageId, createdAt])
  @@index([saleId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  iv        String?
}

model SubscriptionPlan {
  id                String         @id @default(cuid())
  name              String         @unique
  description       String?
  monthlyPriceCents Int            @default(0)
  yearlyPriceCents  Int            @default(0)
  maxShops          Int            @default(1)
  maxUsers          Int            @default(3)
  maxCustomers      Int            @default(50)
  features          String         @default("[]")
  isActive          Boolean        @default(true)
  sortOrder         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  isDefault         Boolean        @default(false)
  trialDays         Int            @default(14)
  subscriptions     Subscription[]
}

model Subscription {
  id            String             @id @default(cuid())
  shopId        String             @unique
  planId        String
  status        SubscriptionStatus @default(TRIAL)
  billingCycle  String             @default("monthly")
  amountCents   Int                @default(0)
  startDate     DateTime           @default(now())
  endDate       DateTime?
  trialEndsAt   DateTime?
  paidAt        DateTime?
  paidUntil     DateTime?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  cancelledAt   DateTime?
  cancelledById String?
  suspendReason String?
  plan          SubscriptionPlan   @relation(fields: [planId], references: [id])
  shop          Shop               @relation(fields: [shopId], references: [id])
  logs          SubscriptionLog[]

  @@index([shopId])
  @@index([status])
}

model SubscriptionLog {
  id             String        @id @default(cuid())
  subscriptionId String?
  shopId         String
  action         String
  planId         String?
  amountCents    Int?
  prevStatus     String?
  newStatus      String?
  notes          String?
  createdById    String?
  createdAt      DateTime      @default(now())
  shop           Shop          @relation(fields: [shopId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([shopId, createdAt])
  @@index([subscriptionId, createdAt])
}

model PaymentProvider {
  id                  String               @id @default(cuid())
  name                String               @unique
  kind                String               @default("MANUAL")
  isActive            Boolean              @default(true)
  instructions        String?
  contactInfo         String?
  logoUrl             String?
  sortOrder           Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  paymentTransactions PaymentTransaction[]
}

model PaymentTransaction {
  id            String          @id @default(cuid())
  shopId        String
  providerId    String
  amountCents   Int
  status        String          @default("PENDING")
  reference     String?
  notes         String?
  confirmedById String?
  confirmedAt   DateTime?
  createdAt     DateTime        @default(now())
  screenshotUrl String?
  provider      PaymentProvider @relation(fields: [providerId], references: [id])
  shop          Shop            @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([status])
}

model SystemBanner {
  id        String    @id @default(cuid())
  message   String
  type      String    @default("info")
  shopId    String?
  isActive  Boolean   @default(true)
  startAt   DateTime?
  endAt     DateTime?
  createdBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  shop      Shop?     @relation(fields: [shopId], references: [id])

  @@index([shopId, isActive])
  @@index([isActive])
}

model ShopSetting {
  id        String   @id @default(cuid())
  shopId    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id])

  @@unique([shopId, key])
}

model AuditLog {
  id          String   @id @default(cuid())
  shopId      String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  beforeJson  String?
  afterJson   String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id])
  shop        Shop?    @relation(fields: [shopId], references: [id])

  @@index([shopId, createdAt])
  @@index([actorUserId])
  @@index([entityType, entityId])
}

model CustomerOrder {
  id             String              @id @default(cuid())
  shopId         String
  customerId     String
  status         OrderStatus         @default(PENDING)
  notes          String?
  subtotalCents  Int                 @default(0)
  saleId         String?
  confirmedAt    DateTime?
  confirmedById  String?
  rejectedAt     DateTime?
  rejectedById   String?
  rejectedReason String?
  cancelledAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  confirmedBy    User?               @relation("OrderConfirmedBy", fields: [confirmedById], references: [id])
  customer       Customer            @relation(fields: [customerId], references: [id])
  sale           Sale?               @relation(fields: [saleId], references: [id])
  shop           Shop                @relation(fields: [shopId], references: [id])
  lines          CustomerOrderLine[]

  @@index([shopId, status])
  @@index([shopId, customerId])
  @@index([shopId, createdAt])
}

model CustomerOrderLine {
  id                  String        @id @default(cuid())
  orderId             String
  beverageId          String
  boxes               Int           @default(0)
  bottles             Int           @default(0)
  pricePerBoxCents    Int           @default(0)
  pricePerBottleCents Int           @default(0)
  lineTotalCents      Int           @default(0)
  beverage            Beverage      @relation(fields: [beverageId], references: [id])
  order               CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model CustomerEmailVerificationToken {
  id         String    @id @default(cuid())
  customerId String
  codeHash   String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerPinResetToken {
  id         String    @id @default(cuid())
  customerId String
  codeHash   String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model TelegramLinkCode {
  id        String    @id @default(cuid())
  code      String    @unique
  kind      String
  targetId  String
  shopId    String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([targetId])
  @@index([expiresAt])
}

enum UserRole {
  OWNER
  EMPLOYEE
  SUPER_ADMIN
  ADMIN
}

enum SaleStatus {
  OPEN
  CONFIRMED
  VOIDED
}

enum VerificationChannel {
  PHONE
  EMAIL
  TELEGRAM
  WHATSAPP
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  OTHER
}

enum PaymentAccountKind {
  CASH_PERSON
  BANK
  MOBILE_MONEY
  OTHER
}

enum PriceTierKind {
  RETAIL
  WHOLESALE
  VIP
  CUSTOM
}

enum StockMovementReason {
  SALE
  SALE_VOID
  PURCHASE
  ADJUSTMENT
  RETURN
  SWAP
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELLED
  EXPIRED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

model ProcessedMutation {
  id               String   @id @default(cuid())
  clientMutationId String   @unique
  serverId         String?
  entityType       String
  shopId           String
  createdAt        DateTime @default(now())

  @@index([shopId, clientMutationId])
}
